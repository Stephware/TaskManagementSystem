@TaskManagementSystem_HostAddress = http://localhost:5012

GET {{TaskManagementSystem_HostAddress}}/weatherforecast/
Accept: application/json

###

// test: login as admin (API key + JWT generation)
POST {{TaskManagementSystem_HostAddress}}/api/auth/login
Content-Type: application/json
X-API-KEY: MYAPIKEY

{
  "username": "admin",
  "password": "admin123"
}

###

// test: login as manager (API key + JWT generation)
POST {{TaskManagementSystem_HostAddress}}/api/auth/login
Content-Type: application/json
X-API-KEY: MYAPIKEY

{
  "username": "manager",
  "password": "manager123"
}

###

// test: login as employee (API key + JWT generation)
POST {{TaskManagementSystem_HostAddress}}/api/auth/login
Content-Type: application/json
X-API-KEY: MYAPIKEY

{
  "username": "employee",
  "password": "employee123"
}

