###

// test: admin access to admin-only endpoint (should succeed)
GET {{TaskManagementSystem_HostAddress}}/api/admin/users
Authorization: Bearer {{adminToken}}

###

// test: employee trying admin endpoint (should fail - 403)
GET {{TaskManagementSystem_HostAddress}}/api/admin/users
Authorization: Bearer {{employeeToken}}

###

// test: delete user (admin only)
DELETE {{TaskManagementSystem_HostAddress}}/api/admin/users/2
Authorization: Bearer {{adminToken}}

###

// test: delete same user again (should return 404)
DELETE {{TaskManagementSystem_HostAddress}}/api/admin/users/2
Authorization: Bearer {{adminToken}}

###

// test: get tasks (manager access allowed)
GET {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{managerToken}}

###

// test: create task (manager only)
POST {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{managerToken}}

###

// test: update task (manager only)
PUT {{TaskManagementSystem_HostAddress}}/api/tasks/1
Authorization: Bearer {{managerToken}}

###

// test: employee viewing tasks (allowed)
GET {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{employeeToken}}

###

// test: employee creating task (should fail - 403)
POST {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{employeeToken}}

###

// test: rate limiting for admin (3 req/min)

###
GET {{TaskManagementSystem_HostAddress}}/api/admin/users
Authorization: Bearer {{adminToken}}

###

// test: rate limiting for employee task view (20 req/min)
GET {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{employeeToken}}

###

// test: rate limiting for manager task write (10 req/min)
POST {{TaskManagementSystem_HostAddress}}/api/tasks
Authorization: Bearer {{managerToken}}