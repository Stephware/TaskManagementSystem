POST {{TaskManagementSystem_HostAddress}}/api/auth/login
Content-Type: application/json
X-API-KEY: MYAPIKEY

{
  "username": "manager",
  "password": "manager123"
}

###

// test: login as employee (API key and JWT generation)
POST {{TaskManagementSystem_HostAddress}}/api/auth/login
Content-Type: application/json
X-API-KEY: MYAPIKEY

{
  "username": "employee",
  "password": "employee123"
}

